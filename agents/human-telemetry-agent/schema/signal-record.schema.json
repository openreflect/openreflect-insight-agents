{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/human-telemetry-agent/signal-record.schema.json",
  "title": "Human Telemetry Signal Record",
  "type": "object",
  "required": [
    "id",
    "observed_at",
    "source_system",
    "source_type",
    "source_ref",
    "person_ref",
    "sentiment",
    "state_labels",
    "confidence",
    "recency_bucket",
    "interpretation",
    "recommended_assistant_action",
    "needs_checkin",
    "privacy"
  ],
  "properties": {
    "id": { "type": "string" },
    "observed_at": { "type": "string", "format": "date-time" },
    "referenced_at": { "type": ["string", "null"], "format": "date-time" },
    "source_system": { "type": "string" },
    "source_type": { "type": "string" },
    "source_ref": { "type": "string" },
    "person_ref": { "type": "string" },
    "project_ref": { "type": ["string", "null"] },
    "sentiment": {
      "type": "string",
      "enum": ["positive", "neutral", "negative", "mixed", "unknown"]
    },
    "state_labels": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "recency_bucket": {
      "type": "string",
      "enum": ["present", "recent", "near_history", "medium_history", "long_history", "unknown"]
    },
    "evidence_excerpt": { "type": ["string", "null"] },
    "interpretation": { "type": "string" },
    "recommended_assistant_action": { "type": "string" },
    "needs_checkin": { "type": "boolean" },
    "checkin_question": { "type": ["string", "null"] },
    "privacy": {
      "type": "string",
      "enum": ["public", "synthetic", "private", "restricted"]
    }
  },
  "additionalProperties": false
}
